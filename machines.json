:root{
  --bg:#f5f7fb;
  --card:#ffffff;
  --text:#1a1f2b;
  --muted:#667085;
  --line:#d9e0ea;
  --accent:#1f6feb;
  --accent-dark:#1658b8;
  --ok-bg:#ecfdf3;
  --ok-text:#027a48;
  --warn-bg:#fff7ed;
  --warn-text:#b54708;
  --shadow:0 10px 30px rgba(16,24,40,.08);
  --radius:18px;
}

*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
  font-family:-apple-system,BlinkMacSystemFont,"Hiragino Kaku Gothic ProN","Yu Gothic","Meiryo",sans-serif;
  background:linear-gradient(180deg,#f7f9fc 0%, #eef3f8 100%);
  color:var(--text);
  line-height:1.7;
}

a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}

.site-header{
  background:#fff;
  border-bottom:1px solid var(--line);
  position:sticky;
  top:0;
  z-index:10;
  backdrop-filter:saturate(180%) blur(8px);
}

.site-header-inner,
.page,
.site-footer-inner{
  width:min(100%, 980px);
  margin:0 auto;
  padding-left:20px;
  padding-right:20px;
}

.site-header-inner{
  min-height:68px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
}

.brand{
  font-size:1.1rem;
  font-weight:800;
  color:var(--text);
}

.header-nav{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
}

.header-nav a{
  color:var(--muted);
  font-weight:600;
  font-size:.95rem;
}

.page{
  padding-top:28px;
  padding-bottom:48px;
}

.hero{
  margin-bottom:20px;
}

.eyebrow{
  display:inline-block;
  padding:6px 10px;
  background:#e8f1ff;
  color:var(--accent-dark);
  border-radius:999px;
  font-size:.82rem;
  font-weight:700;
  line-height:1;
  margin-bottom:12px;
}

.page-title{
  font-size:clamp(1.9rem,4vw,2.8rem);
  line-height:1.2;
  margin:0 0 12px;
  letter-spacing:.01em;
}

.lead{
  color:var(--muted);
  font-size:1.03rem;
  margin:0;
}

.grid{
  display:grid;
  gap:20px;
}

.grid-2{
  grid-template-columns:1.35fr .85fr;
}

.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  padding:24px;
}

.card h2,
.card h3{
  margin:0 0 12px;
  line-height:1.35;
}

.meta-list,
.point-list{
  margin:0;
  padding-left:1.2rem;
}

.meta-list li,
.point-list li{
  margin:6px 0;
}

.notice{
  border-radius:14px;
  padding:14px 16px;
  margin-top:14px;
  font-weight:700;
}

.notice-ok{
  background:var(--ok-bg);
  color:var(--ok-text);
}

.notice-warn{
  background:var(--warn-bg);
  color:var(--warn-text);
}

.checker-box{
  display:grid;
  gap:14px;
}

.form-row{
  display:grid;
  gap:10px;
}

label{
  font-size:.95rem;
  font-weight:700;
}

input[type="number"],
input[type="search"]{
  width:100%;
  border:1px solid var(--line);
  border-radius:14px;
  padding:14px 16px;
  font-size:1rem;
  background:#fff;
  outline:none;
}

input[type="number"]:focus,
input[type="search"]:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 4px rgba(31,111,235,.12);
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border:none;
  border-radius:14px;
  padding:14px 18px;
  background:var(--accent);
  color:#fff;
  font-size:1rem;
  font-weight:800;
  cursor:pointer;
  transition:background .15s ease, transform .05s ease;
}

.btn:hover{
  background:var(--accent-dark);
  text-decoration:none;
}

.btn:active{
  transform:translateY(1px);
}

.result-box{
  min-height:64px;
  border:1px dashed var(--line);
  border-radius:14px;
  padding:16px;
  background:#fafcff;
}

.result-text{
  margin:0;
  font-size:1rem;
  font-weight:800;
}

.cta-row{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
  margin-top:18px;
}

.btn-sub{
  background:#fff;
  color:var(--text);
  border:1px solid var(--line);
}

.site-footer{
  border-top:1px solid var(--line);
  background:#fff;
}

.site-footer-inner{
  padding-top:22px;
  padding-bottom:22px;
  color:var(--muted);
  font-size:.92rem;
}

.index-toolbar{
  display:flex;
  justify-content:space-between;
  align-items:end;
  gap:20px;
  margin-bottom:20px;
}

.section-title{
  margin:0 0 6px;
  line-height:1.3;
}

.lead-inline{
  margin:0;
  color:var(--muted);
}

.search-wrap{
  min-width:min(100%, 320px);
}

.search-label{
  display:block;
  margin-bottom:8px;
}

.machine-grid{
  display:grid;
  grid-template-columns:repeat(3, minmax(0, 1fr));
  gap:20px;
}

.machine-card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  padding:22px;
}

.machine-card-head{
  margin-bottom:12px;
}

.machine-badge{
  display:inline-block;
  padding:6px 10px;
  background:#e8f1ff;
  color:var(--accent-dark);
  border-radius:999px;
  font-size:.78rem;
  font-weight:800;
  line-height:1;
  margin-bottom:10px;
}

.machine-title{
  margin:0;
  font-size:1.35rem;
  line-height:1.35;
}

.machine-slug{
  margin:0 0 16px;
  color:var(--muted);
  font-size:.92rem;
}

.machine-links{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

.empty-message{
  color:var(--muted);
}

@media (max-width: 980px){
  .machine-grid{grid-template-columns:repeat(2, minmax(0, 1fr));}
}

@media (max-width: 820px){
  .grid-2{grid-template-columns:1fr}
  .site-header-inner{
    align-items:flex-start;
    padding-top:14px;
    padding-bottom:14px;
    flex-direction:column;
  }
  .card{padding:20px}
  .index-toolbar{
    flex-direction:column;
    align-items:stretch;
  }
}

@media (max-width: 640px){
  .machine-grid{grid-template-columns:1fr;}
}